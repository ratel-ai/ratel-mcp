{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/log-tool-usage.mjs\" PreToolUse",
            "statusMessage": "Logging Ratel tool usage",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/log-tool-usage.mjs\" PostToolUse",
            "statusMessage": "Logging Ratel tool usage",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/capture-chat.mjs\" UserPromptSubmit",
            "statusMessage": "Capturing chat for Ratel intents",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/capture-chat.mjs\" Stop",
            "statusMessage": "Capturing chat for Ratel intents",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
